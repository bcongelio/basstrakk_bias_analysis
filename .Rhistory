# Define all 2025 Bassmaster Elite Series tournaments
tournaments_2025 <- tribble(
~tournament_id, ~event_name,         ~location,            ~state, ~start_date,
1577,           "St. Johns River",   "Palatka",            "FL",   "2025-02-20",
1578,           "Lake Okeechobee",   "Okeechobee",         "FL",   "2025-02-27",
1579,           "Pasquotank River",  "Elizabeth City",     "NC",   "2025-04-10",
1580,           "Lake Hartwell",     "Anderson",           "SC",   "2025-04-24",
1581,           "Lake Fork",         "Yantis",             "TX",   "2025-05-08",
1582,           "Sabine River",      "Orange",             "TX",   "2025-05-15",
1583,           "Lake Tenkiller",    "Cookson",            "OK",   "2025-06-12",
1584,           "Lake St. Clair",    "Macomb County",      "MI",   "2025-08-07",
1585,           "Mississippi River", "La Crosse",          "WI",   "2025-08-21")
##########################
## CORE SCRAPING FUNCTIONS
##########################
# --- helper: safely fetch JSON from a Bassmaster endpoint --- #
fetch_json <- function(url) {
request(url) |>
req_perform() |>
resp_body_json()
}
# --- fetch official final standing for a tournament --- #
fetch_final_results <- function(tournament_id) {
url <- paste0("https://www.bassmaster.com/wp-json/data/v1/tournament/final-results","?class=anglers&tournament_id=", tournament_id)
fetch_json(url) |>
bind_rows() |>
select(FishermenId, name, final_weight, place, prize_money, totalWinnings) |>
rename(
angler_id = FishermenId,
angler_name = name,
official_oz = final_weight,
official_place = place) |>
mutate(tournament_id = tournament_id)
}
# --- fetch daily leaderboard (for BTLimitOunces - official daily bag weight) --- #
fetch_daily_leaderboard <- function(tournament_id, date_str) {
url <- paste0("https://www.bassmaster.com/wp-json/data/v1/tournament/basstrakk/leaderboard","?tournament_id=", tournament_id, "&daydate=", date_str)
fetch_json(url) |>
bind_rows() |>
select(FISHERMENID, FISHERMAN_PHONENAME, BTLimitOunces, BTFishCount) |>
rename(
angler_id = FISHERMENID,
angler_name_lb = FISHERMAN_PHONENAME,
day_oz_official = BTLimitOunces,
day_fish_count = BTFishCount)
}
# --- fetch individual catch records for a single day --- #
fetch_daily_catches <- function(tournament_id, date_str) {
url <- paste0("https://www.bassmaster.com/wp-json/data/v1/tournament/basstrakk/catches","?tournament_id=", tournament_id, "&daydate=", date_str)
fetch_json(url)
}
##########################
## FULL TOURNAMENT SCRAPE
##########################
scrape_full_tournament <- function(tournament_id, start_date, num_days = 4,
event_name = NA, sleep_sec = 2) {
message("Scraping tournament ", tournament_id, " (", event_name, ")...")
dates        <- seq(as.Date(start_date), by = "day", length.out = num_days)
date_strings <- format(dates, "%Y%m%d")
# --- 1. official final standings (single call, authoritative) --- #
final_standings <- fetch_final_results(tournament_id)
Sys.sleep(sleep_sec)
# --- 2. daily leaderboards (for per-day official bag weights) --- #
daily_leaderboards <- list()
for (i in seq_along(date_strings)) {
tryCatch({
lb <- fetch_daily_leaderboard(tournament_id, date_strings[i]) |>
mutate(day = i, date = as.character(dates[i]))
daily_leaderboards <- c(daily_leaderboards, list(lb))
Sys.sleep(sleep_sec)
}, error = function(e) {
warning(paste("Leaderboard error - tournament:", tournament_id,
"date:", date_strings[i], "-", e$message))
})
}
daily_lb_df <- bind_rows(daily_leaderboards)
# --- 3. individual catches across all days --- #
all_catches <- list()
for (i in seq_along(date_strings)) {
tryCatch({
day_data <- fetch_daily_catches(tournament_id, date_strings[i])
if (length(day_data) > 0) {
day_data <- lapply(day_data, function(x) {
x$day  <- i
x$date <- as.character(dates[i])
if (!is.null(x$Time)) {
parsed_time       <- as.POSIXct(x$Time, format = "%Y-%m-%dT%H:%M:%S")
x$catch_time      <- format(parsed_time, "%H:%M:%S")
x$clock_hour      <- hour(parsed_time)
x$tournament_hour <- x$clock_hour - 6
}
x
})
}
all_catches <- c(all_catches, day_data)
Sys.sleep(sleep_sec)
}, error = function(e) {
warning(paste("Catches error - tournament:", tournament_id,
"date:", date_strings[i], "-", e$message))
})
}
catch_df <- bind_rows(all_catches) |>
mutate(tournament_id = tournament_id, event_name = event_name)
# --- 4. join everything: catches + official standings + daily leaderboards --- #
result <- catch_df |>
left_join(final_standings,
by = c("AnglerId" = "angler_id", "tournament_id" = "tournament_id")) |>
left_join(daily_lb_df |> select(angler_id, day, day_oz_official, day_fish_count),
by = c("AnglerId" = "angler_id", "day" = "day")) |>
arrange(official_place, day, catch_time) |>
group_by(AnglerId, tournament_id) |>
mutate(catch_number = row_number()) |>
ungroup() |>
mutate(
weight_lbs_oz   = FishWeight,
weight_decimal  = as.numeric(gsub("-", ".", FishWeight)),
official_lbs_oz = paste0(official_oz %/% 16, "-",
formatC(official_oz %% 16, width = 2, flag = "0")))
message("  ", nrow(result), " catches scraped, ",
n_distinct(result$AnglerId), " anglers")
return(result)
}
##########################
## VALIDATION FUNCTION
##########################
validate_tournament <- function(scraped_data) {
# --- compare scraped catch totals (using official daily limits to official tournament results)
validation <- scraped_data |>
distinct(tournament_id, event_name, AnglerId, angler_name,
day, day_oz_official, official_oz, official_place) |>
group_by(tournament_id, event_name, AnglerId, angler_name, official_oz, official_place) |>
summarize(
sum_daily_oz = sum(day_oz_official, na.rm = TRUE),
n_days = n(),
.groups = "drop") |>
mutate(
diff_oz = sum_daily_oz - official_oz,
pct_diff = round(100 * diff_oz / pmax(official_oz, 1), 2),
validation = case_when(
is.na(official_oz) ~ "no_official_total",
abs(diff_oz) <= 2 ~ "match",
abs(diff_oz) <= 16 ~ "minor_diff",
TRUE ~ "MAJOR_DIFF"))
summary_stats <- validation |>
count(tournament_id, event_name, validation) |>
pivot_wider(names_from = validation, values_from = n, values_fill = 0)
list(
angler_level = validation,
summary = summary_stats)
}
##########################
## SCRAPE THE FULL SEASON
##########################
library(tictoc)
# --- run all 9 tournaments with 2-second delays in 4 minutes --- #
tic()
season_2025 <- tournaments_2025 |>
pmap_dfr(function(tournament_id, event_name, location, state, start_date) {
scrape_full_tournament(
tournament_id = tournament_id,
start_date = start_date,
num_days = 4,
event_name = event_name,
sleep_sec = 2)
})
toc()
# --- validate --- #
validation_results <- validate_tournament(season_2025)
master_summary <- season_2025 |>
filter(IsKept == "Y") |>
group_by(tournament_id, event_name, AnglerId, day) |>
summarise(
day_top5 = sum(sort(FishWeightOz, decreasing = TRUE)[1:5], na.rm = TRUE),
.groups = "drop_last"
) |>
group_by(tournament_id, event_name, AnglerId) |>
summarise(
bt_tournament_total = sum(day_top5),
days_tracked        = n(),
.groups = "drop"
) |>
left_join(
season_2025 |> distinct(tournament_id, AnglerId, angler_name, official_oz, official_place),
by = c("tournament_id", "AnglerId")
) |>
filter(!is.na(official_oz), official_oz > 0) |>
mutate(
expected_days = case_when(
official_place <= 10 ~ 4L,
official_place <= 50 ~ 3L,
TRUE                 ~ 2L
),
full_coverage = days_tracked == expected_days,
diff_oz       = bt_tournament_total - official_oz,
bias_ratio    = bt_tournament_total / official_oz,
exact_match   = diff_oz == 0
)
day4_comparison <- master_summary |>
filter(full_coverage, event_name != "Lake Fork") |>
mutate(
cut_tier = case_when(
official_place <= 10  ~ "top_10_fished_day4",
official_place <= 50  ~ "11_to_50_no_day4",
TRUE                  ~ "below_50_days_1_2_only"
)
) |>
group_by(cut_tier) |>
summarise(
n           = n(),
mean_bias   = round(mean(bias_ratio), 3),
median_bias = round(median(bias_ratio), 3),
sd_bias     = round(sd(bias_ratio), 3),
.groups = "drop"
)
print(day4_comparison)
# Statistical test
day4_data <- master_summary |>
filter(full_coverage, event_name != "Lake Fork") |>
mutate(fished_day_4 = official_place <= 10)
t.test(bias_ratio ~ fished_day_4, data = day4_data)
# Clean version of the coverage table for Results
coverage_by_tournament <- season_2025 |>
group_by(tournament_id, event_name, day) |>
summarise(
anglers_with_catches = n_distinct(AnglerId),
total_catches        = n(),
.groups = "drop"
) |>
left_join(
tournaments_2025 |> select(tournament_id, event_name),
by = c("tournament_id", "event_name")
) |>
mutate(
expected_anglers = case_when(
day == 1 ~ 102L,  # approximate full field
day == 2 ~ 102L,
day == 3 ~ 50L,
day == 4 ~ 10L
),
coverage_pct = round(100 * anglers_with_catches / expected_anglers, 1)
) |>
select(event_name, day, expected_anglers, anglers_with_catches, coverage_pct) |>
arrange(event_name, day)
# Summary stats across all tournaments
coverage_by_tournament |>
group_by(day) |>
summarise(
mean_coverage = round(mean(coverage_pct), 1),
min_coverage  = min(coverage_pct),
max_coverage  = max(coverage_pct),
.groups = "drop"
)
# The key table showing exact-match rates, bias, and coverage
tournament_summary <- master_summary |>
group_by(event_name) |>
summarise(
n_anglers           = n(),
pct_full_coverage   = round(100 * mean(full_coverage), 1),
pct_exact_match     = round(100 * mean(exact_match), 1),
pct_within_1lb      = round(100 * mean(abs(diff_oz) <= 16), 1),
mean_bias           = round(mean(bias_ratio), 3),
median_bias         = round(median(bias_ratio), 3),
sd_bias             = round(sd(bias_ratio), 3),
.groups = "drop"
) |>
arrange(event_name)
print(tournament_summary)
# Already have this from earlier, but need the full cluster membership table
angler_typology <- angler_stability |>
select(angler_name, n_tournaments, mean_bias, sd_bias, avg_place, cluster) |>
arrange(cluster, mean_bias)
##########################
## ISOLATING REPORTING BIAS
## (Only anglers tracked all 4 days — no coverage gap)
##########################
# Per angler-tournament: did BassTrakk track them every day?
angler_tournament_summary <- season_2025 |>
filter(IsKept == "Y") |>
group_by(tournament_id, event_name, AnglerId, angler_name) |>
summarise(
bt_total_oz   = sum(sort(FishWeightOz, decreasing = TRUE)[1:5], na.rm = TRUE),
days_tracked  = n_distinct(day),
.groups = "drop"
) |>
left_join(
season_2025 |> distinct(tournament_id, AnglerId, official_oz, official_place),
by = c("tournament_id", "AnglerId")
) |>
filter(!is.na(official_oz), official_oz > 0)
# But wait — this isn't quite right either. We need top 5 PER DAY summed,
# not top 5 across the whole tournament. Let me redo it.
angler_tournament_summary <- season_2025 |>
filter(IsKept == "Y") |>
group_by(tournament_id, event_name, AnglerId, angler_name, day) |>
summarise(
day_top5_oz = sum(sort(FishWeightOz, decreasing = TRUE)[1:5], na.rm = TRUE),
.groups = "drop_last"
) |>
group_by(tournament_id, event_name, AnglerId, angler_name) |>
summarise(
bt_tournament_oz = sum(day_top5_oz),
days_tracked     = n(),
.groups = "drop"
) |>
left_join(
season_2025 |> distinct(tournament_id, AnglerId, official_oz, official_place),
by = c("tournament_id", "AnglerId")
) |>
filter(!is.na(official_oz), official_oz > 0)
# How many days did each angler ACTUALLY fish (based on cut structure)?
# Day 1-2: full field
# Day 3: top 50 cumulative after day 2
# Day 4: top 10 cumulative after day 3
#
# An angler who finished e.g. 25th would have fished days 1, 2, and 3 (3 days)
# An angler who finished 60th would have fished days 1 and 2 (2 days)
angler_tournament_summary <- angler_tournament_summary |>
mutate(
expected_days = case_when(
official_place <= 10 ~ 4L,
official_place <= 50 ~ 3L,
TRUE                 ~ 2L
),
full_coverage = days_tracked == expected_days,
bias_ratio    = bt_tournament_oz / official_oz
)
# Reporting bias for FULLY-COVERED anglers only (no coverage gaps possible)
reporting_bias_clean <- angler_tournament_summary |>
filter(full_coverage, event_name != "Lake Fork")
# Distribution by tournament
reporting_bias_clean |>
group_by(event_name) |>
summarise(
n_anglers     = n(),
mean_bias     = round(mean(bias_ratio), 3),
median_bias   = round(median(bias_ratio), 3),
sd_bias       = round(sd(bias_ratio), 3),
.groups = "drop"
) |>
arrange(mean_bias)
# Per-angler reporting bias across the season
per_angler_reporting <- reporting_bias_clean |>
group_by(AnglerId, angler_name) |>
summarise(
n_tournaments = n(),
mean_bias     = mean(bias_ratio),
median_bias   = median(bias_ratio),
sd_bias       = sd(bias_ratio),
avg_place     = mean(official_place),
.groups = "drop"
) |>
filter(n_tournaments >= 4)
# Top sandbaggers (only fully-covered angler-tournaments)
per_angler_reporting |> arrange(mean_bias) |> head(15)
# Most accurate
per_angler_reporting |> arrange(desc(mean_bias)) |> head(15)
# Test the skill correlation again with cleaner data
cor.test(per_angler_reporting$mean_bias, per_angler_reporting$avg_place,
method = "spearman")
# Rebuild angler_stability with clustering
library(mclust)
# Start from the per_angler_reporting data (which you already have)
angler_stability <- per_angler_reporting |>
select(AnglerId, angler_name, n_tournaments, mean_bias, sd_bias, avg_place)
# Run clustering on (mean_bias, sd_bias)
cluster_data <- angler_stability |> select(mean_bias, sd_bias) |> as.matrix()
mc <- Mclust(cluster_data, G = 2:4)
angler_stability$cluster <- mc$classification
# Summary by cluster
cluster_summary <- angler_stability |>
group_by(cluster) |>
summarise(
n_anglers       = n(),
mean_of_means   = round(mean(mean_bias), 3),
sd_of_means     = round(sd(mean_bias), 3),
mean_of_sds     = round(mean(sd_bias), 3),
mean_avg_place  = round(mean(avg_place), 1),
.groups = "drop"
)
print(cluster_summary)
# Example anglers from each cluster
angler_stability |>
group_by(cluster) |>
slice_head(n = 8) |>
select(cluster, angler_name, n_tournaments, mean_bias, sd_bias, avg_place)
# Already have from earlier but need clean output
cor_test_result <- cor.test(per_angler_reporting$mean_bias,
per_angler_reporting$avg_place,
method = "spearman")
# Also useful: a simple scatterplot summary
bias_place_summary <- per_angler_reporting |>
mutate(
place_tier = case_when(
avg_place <= 20  ~ "Elite (avg 1-20)",
avg_place <= 40  ~ "High (avg 21-40)",
avg_place <= 60  ~ "Middle (avg 41-60)",
TRUE             ~ "Lower (avg 61+)"
)
) |>
group_by(place_tier) |>
summarise(
n          = n(),
mean_bias  = round(mean(mean_bias), 3),
median_bias = round(median(mean_bias), 3),
.groups = "drop"
)
print(bias_place_summary)
# Does bias correlate with fish size?
# Use Lake Fork (trophy), Florida grass (big), smallmouth (smaller) as proxies
venue_bias <- reporting_bias_clean |>
mutate(
venue_type = case_when(
event_name %in% c("St. Johns River", "Lake Okeechobee") ~ "Florida grass",
event_name %in% c("Lake Fork") ~ "Trophy reservoir",
event_name %in% c("Lake St. Clair", "Mississippi River") ~ "Smallmouth",
event_name %in% c("Sabine River") ~ "Tidal/river",
TRUE ~ "Other reservoir"
)
) |>
group_by(venue_type) |>
summarise(
n_observations = n(),
mean_bias      = round(mean(bias_ratio), 3),
median_bias    = round(median(bias_ratio), 3),
sd_bias        = round(sd(bias_ratio), 3),
.groups = "drop"
) |>
arrange(mean_bias)
print(venue_bias)
# Already have these but need clean versions for the text
top_sandbaggers <- per_angler_reporting |>
arrange(mean_bias) |>
head(10) |>
select(angler_name, n_tournaments, mean_bias, sd_bias, avg_place)
most_accurate <- per_angler_reporting |>
arrange(desc(mean_bias)) |>
head(10) |>
select(angler_name, n_tournaments, mean_bias, sd_bias, avg_place)
print(top_sandbaggers)
print(most_accurate)
# Already computed but need formatted
lake_fork_reconciliation <- master_summary |>
filter(event_name == "Lake Fork") |>
summarise(
n_anglers      = n(),
n_exact        = sum(exact_match),
n_within_1lb   = sum(abs(diff_oz) <= 16),
pct_exact      = round(100 * n_exact / n_anglers, 1),
pct_within_1lb = round(100 * n_within_1lb / n_anglers, 1),
mean_bias      = round(mean(bias_ratio), 3),
median_bias    = round(median(bias_ratio), 3)
)
print(lake_fork_reconciliation)
# Also: who were the non-reconciled anglers at Lake Fork?
lake_fork_non_reconciled <- master_summary |>
filter(event_name == "Lake Fork", !exact_match) |>
select(angler_name, official_place, official_oz, bt_tournament_total, diff_oz, bias_ratio) |>
arrange(desc(abs(diff_oz)))
print(lake_fork_non_reconciled)
